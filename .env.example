# Copy this file to .env and fill in the values below.
# .env is gitignored — your secrets stay local.

# ──────────────────────────────────────────────────────────────────────
# Paths
# ──────────────────────────────────────────────────────────────────────

# Where your live job-search workspace lives (resumes, Excel tracker, Jobs/
# folder). The Excel tracker, per-job folders, dedup file, and logs live here.
BASE_DIR="/Users/you/Desktop/job-search"

# Where the runnable scripts live after you copy them out of this repo. This
# is the path your launchd plist references. Keep this stable — once your
# launchd agent is loaded, moving the scripts requires re-installing the plist.
SCRIPTS_DIR="/Users/you/Library/Application Support/JobSearchAutomation"

# Where logs are written. One log per run; the script keeps the most recent 30.
LOG_DIR="${BASE_DIR}/logs"

# ──────────────────────────────────────────────────────────────────────
# Email
# ──────────────────────────────────────────────────────────────────────

# The address the daily and weekly digests are sent TO. Must be a mailbox
# you can read on whatever device(s) you check email on.
EMAIL_TO="you@example.com"

# ──────────────────────────────────────────────────────────────────────
# Tooling paths
# ──────────────────────────────────────────────────────────────────────

# Absolute path to your Claude CLI binary. Find with: `which claude`.
CLAUDE_BIN="/Users/you/.local/bin/claude"

# Absolute path to a Python 3.11+ interpreter. Find with: `which python3`.
PYTHON_BIN="/Library/Frameworks/Python.framework/Versions/3.13/bin/python3"

# Which Claude model to run as the search agent. Sonnet is a good
# cost/capability balance; Opus is more thorough but slower and pricier.
CLAUDE_MODEL="claude-sonnet-4-6"
