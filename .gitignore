.ruff_cache/

# OS junk
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Vector DBs / caches
*.db
*.sqlite
*.sqlite3

# Tasks (working notes)
tasks/
